# ──────────────────────────────────────────────────────────────────────────────
# SIEM-Integrated File Integrity Monitor — Example Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# All variables are optional — defaults are used when not set.
# ──────────────────────────────────────────────────────────────────────────────

# Elasticsearch connection
ES_HOST=http://localhost:9200
ES_INDEX=fim-events
ES_TIMEOUT=5
# ES_USER=elastic
# ES_PASS=changeme

# Monitoring paths (comma-separated)
WATCH_PATHS=/etc,/home,/var/www

# Ransomware detection tuning
RANSOM_WINDOW=30
RANSOM_THRESHOLD=10
RANSOM_MAX_EXTS=3

# Local storage
DB_PATH=fim_baseline.db
LOG_FILE=fim.log

# Email alerting (uncomment to enable)
# ALERT_EMAIL_ENABLED=true
# ALERT_EMAIL_TO=soc@company.com
# ALERT_EMAIL_FROM=fim@company.com
# SMTP_HOST=smtp.company.com
# SMTP_PORT=587
# SMTP_USER=fim@company.com
# SMTP_PASS=your_password
# SMTP_TLS=true

# Webhook alerting (Slack / Teams / PagerDuty)
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# WEBHOOK_TIMEOUT=10
